root = true

[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
# PascalCase for classes and methods
dotnet_naming_rule.methods_and_properties_must_be_pascal_case.symbols = method_and_property_symbols
dotnet_naming_rule.methods_and_properties_must_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.methods_and_properties_must_be_pascal_case.severity = suggestion

dotnet_naming_symbols.method_and_property_symbols.applicable_kinds = method,property
dotnet_naming_symbols.method_and_property_symbols.applicable_accessibilities = *

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# camelCase for parameters and local variables
dotnet_naming_rule.parameters_and_locals_must_be_camel_case.symbols = parameter_and_local_symbols
dotnet_naming_rule.parameters_and_locals_must_be_camel_case.style = camel_case_style
dotnet_naming_rule.parameters_and_locals_must_be_camel_case.severity = suggestion

dotnet_naming_symbols.parameter_and_local_symbols.applicable_kinds = parameter,local
dotnet_naming_symbols.parameter_and_local_symbols.applicable_accessibilities = *

dotnet_naming_style.camel_case_style.capitalization = camel_case

# Private fields must start with _
dotnet_naming_rule.private_fields_must_start_with_underscore.symbols = private_field_symbols
dotnet_naming_rule.private_fields_must_start_with_underscore.style = private_field_style
dotnet_naming_rule.private_fields_must_start_with_underscore.severity = suggestion

dotnet_naming_symbols.private_field_symbols.applicable_kinds = field
dotnet_naming_symbols.private_field_symbols.applicable_accessibilities = private

dotnet_naming_style.private_field_style.capitalization = camel_case
dotnet_naming_style.private_field_style.required_prefix = _